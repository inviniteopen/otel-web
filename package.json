{
  "name": "@invinite/otel-web",
  "version": "2.1.1",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/inviniteopen/otel-web.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./plugins/fetch": {
      "types": "./dist/plugins/fetch.d.ts",
      "default": "./dist/plugins/fetch.js"
    },
    "./plugins/document-load": {
      "types": "./dist/plugins/document-load.d.ts",
      "default": "./dist/plugins/document-load.js"
    },
    "./plugins/tanstack-router": {
      "types": "./dist/plugins/tanstack-router.d.ts",
      "default": "./dist/plugins/tanstack-router.js"
    },
    "./plugins/tanstack-query": {
      "types": "./dist/plugins/tanstack-query.d.ts",
      "default": "./dist/plugins/tanstack-query.js"
    },
    "./plugins/error-handler": {
      "types": "./dist/plugins/error-handler.d.ts",
      "default": "./dist/plugins/error-handler.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --check src tests",
    "format:fix": "prettier --write src tests",
    "prepublishOnly": "yarn lint && yarn format && yarn build && npm pack --dry-run"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": ">=0.212.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api-logs": {
      "optional": true
    }
  },
  "dependencies": {
    "@opentelemetry/exporter-logs-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.214.0",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/sdk-trace-web": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0"
  },
  "devDependencies": {
    "@invinite/eslint-config": "^1.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.214.0",
    "@vitest/browser": "^4.1.2",
    "@vitest/browser-playwright": "^4.1.2",
    "eslint": "^10.1.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "packageManager": "yarn@4.12.0"
}
